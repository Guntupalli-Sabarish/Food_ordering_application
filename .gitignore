# Global ignore rules for monorepo

# Environment and secret files
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Local scripts that may contain credentials
run-e2e.ps1

# Copilot agent files
.agents/

# Keep local Copilot agent prompts out of git history
.github/agents/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
